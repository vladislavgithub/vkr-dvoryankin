@startuml usecase
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName "Times New Roman"
skinparam defaultFontSize 13
skinparam ActorStyle awesome
skinparam dpi 150
skinparam usecase {
    BackgroundColor #FAFAFA
    BorderColor #555
}
left to right direction

' Портретная компоновка под A4: актёры столбцом слева, use cases —
' тремя вертикальными группами в EduQuiz справа. Скрытые связи между
' актёрами и между пакетами заставляют PlantUML укладывать их сверху вниз.

actor "Преподаватель"  as Teacher
actor "Обучающийся"        as Student
actor "Администратор"  as Admin

Teacher -[hidden]down- Student
Student -[hidden]down- Admin

rectangle "EduQuiz" {
    package "Преподаватель" as PT {
        usecase "Создать курс"                            as UC_CreateCourse
        usecase "Импорт банка вопросов\nиз edu.gubkin"    as UC_ImportBank
        usecase "Создать комнату\nи запустить сессию"     as UC_RunSession
        usecase "Управлять ходом\nинтерактива"            as UC_ControlSession
        usecase "Просмотр аналитики"                      as UC_Analytics
    }

    package "Обучающийся" as PS {
        usecase "Подключиться по коду"        as UC_Join
        usecase "Ответить на вопрос"          as UC_Answer
        usecase "Повторение по SM-2"          as UC_Review
        usecase "Свой прогресс\nи бейджи"     as UC_Progress
    }

    package "Администратор" as PA {
        usecase "Регистрация / вход"          as UC_Login
        usecase "Управление пользователями"   as UC_ManageUsers
        usecase "Управление курсами"          as UC_ManageCourses
    }

    PT -[hidden]down- PS
    PS -[hidden]down- PA
}

Teacher -- UC_CreateCourse
Teacher -- UC_ImportBank
Teacher -- UC_RunSession
Teacher -- UC_ControlSession
Teacher -- UC_Analytics
Teacher -- UC_Login

Student -- UC_Login
Student -- UC_Join
Student -- UC_Answer
Student -- UC_Review
Student -- UC_Progress

Admin -- UC_Login
Admin -- UC_ManageUsers
Admin -- UC_ManageCourses

@enduml
