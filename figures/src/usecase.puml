@startuml usecase
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName "Times New Roman"
skinparam defaultFontSize 13
skinparam ActorStyle awesome
' Компактнее для портретной А4: top to bottom + актёры по краям,
' use cases группируются по ролям внутри пакета.
top to bottom direction

title Диаграмма прецедентов сервиса EduQuiz

actor "Преподаватель" as Teacher
actor "Студент" as Student
actor "Администратор" as Admin

rectangle "EduQuiz" {
    package "Преподаватель" as PT {
        usecase "Регистрация / вход" as UC_Login
        usecase "Создать курс" as UC_CreateCourse
        usecase "Импорт банка\nвопросов из edu.gubkin" as UC_ImportBank
        usecase "Создать комнату\nи запустить сессию" as UC_RunSession
        usecase "Управлять ходом\nинтерактива" as UC_ControlSession
        usecase "Просмотр\nаналитики" as UC_Analytics
    }
    package "Студент" as PS {
        usecase "Подключиться\nпо коду" as UC_Join
        usecase "Ответить\nна вопрос" as UC_Answer
        usecase "Повторение\nпо SM-2" as UC_Review
        usecase "Свой прогресс\nи бейджи" as UC_Progress
    }
    package "Администратор" as PA {
        usecase "Управление\nпользователями" as UC_ManageUsers
        usecase "Управление\nкурсами" as UC_ManageCourses
    }
}

Teacher -- UC_Login
Teacher -- UC_CreateCourse
Teacher -- UC_ImportBank
Teacher -- UC_RunSession
Teacher -- UC_ControlSession
Teacher -- UC_Analytics

Student -- UC_Login
Student -- UC_Join
Student -- UC_Answer
Student -- UC_Review
Student -- UC_Progress

Admin -- UC_Login
Admin -- UC_ManageUsers
Admin -- UC_ManageCourses

@enduml
